# Salin file ini menjadi .env lalu isi dengan nilai asli Anda.
# JANGAN commit file .env ke version control.

# IBM watsonx.ai API Key
# Dapatkan dari: https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=your_ibm_cloud_api_key_here

# watsonx.ai Project ID
# Dapatkan dari halaman Projects di: https://dataplatform.cloud.ibm.com
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# watsonx.ai Service URL (sesuaikan dengan region Anda)
# Contoh region: us-south → https://us-south.ml.cloud.ibm.com
#                eu-de    → https://eu-de.ml.cloud.ibm.com
WATSONX_URL=https://us-south.ml.cloud.ibm.com